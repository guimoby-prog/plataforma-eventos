generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id             String   @id @default(cuid())
  name           String
  description    String?
  startDate      DateTime
  endDate        DateTime
  location       String?
  logoUrl        String?
  bannerUrl      String?
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Visual
  primaryColor   String   @default("#00A859")
  secondaryColor String   @default("#005C2E")
  fontFamily     String   @default("Inter")
  heroTitle      String?
  heroSubtitle   String?
  footerText     String?

  sessions     Session[]
  speakers     Speaker[]
  participants Participant[]
  secoes       Secao[]
  expositores  Expositor[]
}

model Session {
  id          String   @id @default(cuid())
  eventId     String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  track       String?
  day         String?
  createdAt   DateTime @default(now())

  event    Event     @relation(fields: [eventId], references: [id])
  speakers Speaker[] @relation("SessionSpeakers")
  checkins  Checkin[]
  perguntas Pergunta[]
  enquetes  Enquete[]
  avaliacoes Avaliacao[]
}

model Speaker {
  id       String  @id @default(cuid())
  eventId  String
  name     String
  bio      String?
  photoUrl String?
  role     String  @default("Palestrante")

  event    Event     @relation(fields: [eventId], references: [id])
  sessions Session[] @relation("SessionSpeakers")
}

model Category {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Float   @default(0)

  participants Participant[]
}

model Participant {
  id           String    @id @default(cuid())
  eventId      String
  categoryId   String
  name         String
  email        String
  phone        String?
  document     String?
  password     String?
  qrCode          String    @unique @default(cuid())
  lgpdAccepted    Boolean   @default(false)
  faceDescriptor  String?
  fotoFace        String?
  confirmedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  event    Event     @relation(fields: [eventId], references: [id])
  category Category  @relation(fields: [categoryId], references: [id])
  checkins  Checkin[]
  perguntas Pergunta[]
  respostasEnquete RespostaEnquete[]
  avaliacoes Avaliacao[]
  visitas   VisitaExpositor[]

  @@unique([eventId, email])
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Checkin {
  id            String   @id @default(cuid())
  participantId String
  sessionId     String?
  checkedInAt   DateTime @default(now())

  participant Participant @relation(fields: [participantId], references: [id])
  session     Session?    @relation(fields: [sessionId], references: [id])
}

model Expositor {
  id        String   @id @default(cuid())
  eventId   String
  nome      String
  email     String
  senha     String
  qrCode    String   @unique
  pontos    Int      @default(10)
  descricao String?
  createdAt DateTime @default(now())

  event   Event             @relation(fields: [eventId], references: [id])
  visitas VisitaExpositor[]
}

model VisitaExpositor {
  id            String   @id @default(cuid())
  expositorId   String
  participantId String
  createdAt     DateTime @default(now())

  expositor   Expositor   @relation(fields: [expositorId], references: [id])
  participant Participant @relation(fields: [participantId], references: [id])

  @@unique([expositorId, participantId])
}

model Secao {
  id        String   @id @default(cuid())
  eventId   String
  tipo      String   // video | patrocinadores | numeros | depoimentos | faq | texto | banner
  titulo    String?
  conteudo  String   // JSON com dados específicos do tipo
  ordem     Int      @default(0)
  visivel   Boolean  @default(true)
  // Visual
  bgColor   String   @default("#ffffff")
  textColor String   @default("#111827")
  padding   String   @default("py-16")
  align     String   @default("center")
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
}

model Pergunta {
  id            String   @id @default(cuid())
  sessionId     String
  participantId String
  texto         String
  aprovada      Boolean  @default(false)
  respondida    Boolean  @default(false)
  createdAt     DateTime @default(now())

  session     Session     @relation(fields: [sessionId], references: [id])
  participant Participant @relation(fields: [participantId], references: [id])
}

model Enquete {
  id        String   @id @default(cuid())
  sessionId String
  pergunta  String
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())

  session   Session           @relation(fields: [sessionId], references: [id])
  opcoes    OpcaoEnquete[]
  respostas RespostaEnquete[]
}

model OpcaoEnquete {
  id        String @id @default(cuid())
  enqueteId String
  texto     String
  ordem     Int    @default(0)

  enquete   Enquete           @relation(fields: [enqueteId], references: [id])
  respostas RespostaEnquete[]
}

model RespostaEnquete {
  id            String   @id @default(cuid())
  enqueteId     String
  opcaoId       String
  participantId String
  createdAt     DateTime @default(now())

  enquete     Enquete      @relation(fields: [enqueteId], references: [id])
  opcao       OpcaoEnquete @relation(fields: [opcaoId], references: [id])
  participant Participant  @relation(fields: [participantId], references: [id])

  @@unique([enqueteId, participantId])
}

model Avaliacao {
  id            String   @id @default(cuid())
  sessionId     String
  participantId String
  nota          Int
  comentario    String?
  createdAt     DateTime @default(now())

  session     Session     @relation(fields: [sessionId], references: [id])
  participant Participant @relation(fields: [participantId], references: [id])

  @@unique([sessionId, participantId])
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  role      String   @default("Administrador")
  createdAt DateTime @default(now())

  accounts      Account[]
  adminSessions AdminSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AdminSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
